# ─────────────────────────────────────────────────────────────────────────────
# .env.staging — Copia este archivo como .env.staging en el servidor EC2.
# NUNCA subas el .env.staging real a git (ya está en .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# ── Django ──────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=cambia-esto-por-una-cadena-larga-y-aleatoria-de-50-chars
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=planificador.desenvolupament.sarts.dev

# ── Base de datos (PostgreSQL local en Docker) ───────────────────────────────
DB_NAME=loorent_staging
DB_USER=loorent
DB_PASSWORD=cambia-esta-contrasena-db
# DB_HOST se sobreescribe a "db" en docker-compose.staging.yml
DB_PORT=5432

# ── Google Maps ──────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=tu-api-key-aqui

# ── Coordenadas del depósito (por defecto: Palma de Mallorca) ────────────────
DEPOT_LAT=39.679469
DEPOT_LNG=2.834119
DEPOT_NAME=LooRent — Sede
