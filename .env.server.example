# ─── IMPORTANTE ───────────────────────────────────────────────────────────────
# Copia este archivo como .env.server en /srv/planificador_rutas/ del servidor.
# NUNCA subas .env.server a git.
#
# Este archivo controla las variables de los contenedores de BD y del sync.
# Los contenedores web leen sus propios .env.staging / .env.production.
# Las contraseñas de BD DEBEN coincidir con las de dichos archivos.
# ─────────────────────────────────────────────────────────────────────────────

# ── Staging DB ────────────────────────────────────────────────────────────────
# Debe coincidir con DB_NAME / DB_USER / DB_PASSWORD en .env.staging
STAGING_DB_NAME=planificador_staging
STAGING_DB_USER=loorent_staging
STAGING_DB_PASSWORD=genera-una-password-segura-aqui

# ── Producción DB ─────────────────────────────────────────────────────────────
# Debe coincidir con DB_NAME / DB_USER / DB_PASSWORD en .env.production
PROD_DB_NAME=planificador_prod
PROD_DB_USER=loorent_prod
PROD_DB_PASSWORD=genera-otra-password-distinta-aqui
